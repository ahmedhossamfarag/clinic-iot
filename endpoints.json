{
    "version": "1.0",
    "description": "API endpoints for managing and retrieving information about routers, devices, and records.",
    "keys description": {
        "path": "The URL path for the API endpoint.",
        "description": "A brief description of what the endpoint does.",
        "response": "The expected response format for the endpoint."
    },
    "endpoints": [
        {
            "path": "/routers",
            "description": "Get a list of all routers.",
            "response": {
                "routers": [
                    {
                        "id": "UUID",
                        "name": "VarChar(255)",
                        "location_x": "Float",
                        "location_y": "Float"
                    }
                ]
            }
        },
        {
            "path": "/routers/map",
            "description": "Get a map of all routers with their locations and the count of connected devices.",
            "response": {
                "routers_map": [
                    {
                        "id": "UUID",
                        "location_x": "Float",
                        "location_y": "Float",
                        "connected_devices_count": "Int"
                    }
                ]
            }
        },
        {
            "path": "/routers/{id}",
            "description": "Get details of a specific router by its ID.",
            "response": {
                "router": {
                    "id": "UUID",
                    "name": "VarChar(255)",
                    "location_x": "Float",
                    "location_y": "Float"
                }
            }
        },
        {
            "path": "/routers/{id}/devices",
            "description": "Get a list of all devices connected to a specific router by its ID.",
            "response": {
                "devices": [
                    {
                        "id": "UUID",
                        "name": "VarChar(255)",
                        "holder_name": "VarChar(255)",
                        "last_record_timestamp": "Timestamp",
                        "router_id": "UUID",
                        "router_name": "VarChar(255)"
                    }
                ]
            }
        },
        {
            "path": "/routers/{id}/hourly-sessions-duration",
            "description": "Get the number of connected devices and the average session duration for a specific router by its ID.",
            "response": {
                "hourly_sessions": [
                    {
                        "router_id": "UUID",
                        "hour": "Timestamp",
                        "sessions_count": "Int",
                        "average_session_duration": "Timestamp"
                    }
                ]
            }
        },
        {
            "path": "/devices",
            "description": "Get a list of all devices.",
            "response": {
                "devices": [
                    {
                        "id": "UUID",
                        "name": "VarChar(255)",
                        "holder_name": "VarChar(255)"
                    }
                ]
            }
        },
        {
            "path": "/records/hourly-records",
            "description": "Get the number of records created each hour.",
            "response": {
                "records_hourly": [
                    {
                        "hour": "Timestamp",
                        "records_count": "Int"
                    }
                ]
            }
        },
        {
            "path": "/records/hourly-devices",
            "description": "Get the number of unique devices that created records each hour.",
            "response": {
                "records_hourly": [
                    {
                        "hour": "Timestamp",
                        "devices_count": "Int"
                    }
                ]
            }
        },
        {
            "path": "/records/hourly-sessions-duration",
            "description": "Get the average total session duration for each hour.",
            "response": {
                "hourly_sessions": [
                    {
                        "hour": "Timestamp",
                        "average_total_session_duration": "Timestamp"
                    }
                ]
            }
        }
    ]
}